# Ave Narrative Oracle — Backend Environment Variables
# Copy this file to .env and fill in your actual API keys

# AVE Claw Monitoring Skill API Key
# Get yours at: https://ave.ai / https://ave-cloud.gitbook.io/data-api
AVE_API_KEY=your_ave_api_key_here

# MiniMax AI API Key
# Get yours at: https://platform.minimax.io
MINIMAX_API_KEY=your_minimax_api_key_here

# Server Configuration (optional)
HOST=0.0.0.0
PORT=8000

# CORS Origins (comma-separated, or * for all)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
